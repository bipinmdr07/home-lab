TZ=Asia/Kathmandu

DOMAIN=<your domain here>

# Make sure the path starts from root e.g. /mnt/sda1/data
CONFIG_PATH=<path to store config files>
CACHE_PATH=<path to store cache files>
DATA_PATH=<path to store app data>
SHARED_DATA_PATH=<path to share data between containers>

JELLYFIN_MEDIA_PATH=<path to your media files>

# TWINGATE CONFIG
TWINGATE_NETWORK=<TENANT NAME>
TWINGATE_ACCESS_TOKEN=<ACCESS TOKEN>
TWINGATE_REFRESH_TOKEN=<REFRESH TOKEN>


# N8N CONFIG
N8N_ENCRYPTION_KEY=<RANDOM SECRET FOR N8N CREDENTIAL ENCRYPTION>

# POSTGRES CONFIG
DB_USER=<DB USER>
DB_PASSWORD=<DB_PASSWORD>

# IMMICH CONFIG
IMMICH_UPLOAD_PATH=<PATH TO UPLOAD IMAGE>

# MINIO AISTOR CONFIG
MINIO_DATA_PATH=<MINIO DATA PATH>
MINIO_LICENSE_PATH=<ABSOLUTE PATH TO minio.license FILE>
MINIO_ROOT_USER=<MINIO USERNAME (also used as S3 Access Key)>
MINIO_ROOT_PASSWORD=<MINIO PASSWORD (also used as S3 Secret Key)>

# PASSBOLT CONFIG
PASSBOLT_ADMIN_FIRST_NAME=<FIRST NAME>
PASSBOLT_ADMIN_LAST_NAME=<LAST NAME>
EMAIL_FROM=<EMAIL used to send email>
EMAIL_PASSWORD=<EMAIL PASSWORD>

# SYNCTHING PATH
SYNCTHING_DATA_PATH=<PATH TO SOTOR SYNCTHING DATA FOR SYNCING>

# Nextcloud CONFIG
NEXTCLOUD_ADMIN_USER=<NEXTCLOUD ADMIN USERNAME>
NEXTCLOUD_ADMIN_PASSWORD=<NEXTCLOUD ADMIN PASSWORD>

# DOWNLY CONFIG, eg: /Users/$USER/downly
DB_LOCATION=<PATH TO STORE DB>
DOWNLOAD_LOCATION=<PATH TO STORE DOWNLOADS>

# KARAKEEP
KARAKEEP_NEXTAUTH_SECRET=<KARAKEEP SECRET>
MEILI_MASTER_KEY=<MEILI SECRET>

# Frigate
FRIGATE_RTSP_PASSWORD=<FRIGATE_PASSWORD>

# Grimmory - Ebook library; published host port -> container 6060 (override if the host port is taken)
# GRIMMORY_HOST_PORT=6060
# GRIMMORY_DB_PASSWORD is the app DB user password (same value as MYSQL_PASSWORD for grimmory-mariadb).
GRIMMORY_DB_USER=grimmory
GRIMMORY_DB_PASSWORD=<STRONG PASSWORD FOR GRIMMORY DB USER>
GRIMMORY_MYSQL_ROOT_PASSWORD=<STRONG PASSWORD FOR MARIADB ROOT (grimmory-mariadb only)>

# Postiz - Social media scheduling (https://postiz.com); uses shared POSTGRES (DB_USER/DB_PASSWORD), REDIS, and MinIO for storage
POSTIZ_JWT_SECRET=<RANDOM STRING FOR JWT - use a long random secret>
# Optional: set if you expose MinIO S3 API (port 9000) on a different hostname for image URLs, e.g. https://s3.${DOMAIN}/postiz
# POSTIZ_S3_BUCKET_URL=https://minio.${DOMAIN}/postiz
# Optional: POSTIZ_DISABLE_REGISTRATION=false, POSTIZ_OPENAI_API_KEY=, POSTIZ_API_LIMIT=30

# Configuration to setup for homepage stat collection. These values are required after setting up the environment.
# Immich CONFIG
# https://immich.app/docs/features/command-line-interface/#obtain-the-api-key
IMMICH_API_KEY=<YOUR IMMICH API KEY>
JELLYFIN_API_KEY=<YOUR JELLYFIN API KEY>
PORTAINER_API_KEY=<YOUR PORTAINER API KEY>
ADGUARD_USERNAME=<ADGUARD USERNAME>
ADGUARD_PASSWORD=<ADGUARD PASSWORD>
